# Database Configuration
# The backend is Supabase Postgres-only. Prefer the direct Supabase Postgres connection string here.
DB_PROVIDER=postgres
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DB_SSL=true
DB_SYNC=false

# Alternative discrete connection fields
DB_HOST=
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=postgres

# JWT Configuration
JWT_SECRET=change-this-in-production-use-at-least-32-characters
JWT_EXPIRES_IN=7d

# Supabase Auth
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_PASSWORD_REDIRECT_URL=http://localhost:3000/reset-password

# First admin bootstrap
# Set this once, run `npm run bootstrap:admin`, then rotate or remove it after the first admin exists.
# MUST be at least 32 characters for security
BOOTSTRAP_ADMIN_TOKEN=replace-with-a-long-random-one-time-token-minimum-32-chars

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Security: Allowed Origins (comma-separated for multiple origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Email Notifications
RESEND_API_KEY=your-rotated-resend-api-key
RESEND_FROM_EMAIL=ARMS <notifications@your-verified-domain.com>
SUPPORT_EMAIL=support@your-verified-domain.com

# Paystack
PAYSTACK_SECRET_KEY=sk_test_your-paystack-secret-key

# Node Environment
NODE_ENV=development

# Server Port
PORT=3001

# Sentry Error Monitoring (optional)
SENTRY_DSN=

# Session Security
SESSION_SECRET=change-this-to-a-random-string-at-least-32-characters
