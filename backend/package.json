{
  "name": "arms-backend",
  "version": "1.0.0",
  "description": "ARMS Backend API",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "postinstall": "npm run build",
    "apply:sql": "node scripts/apply-sql.js",
    "apply:billing": "node scripts/apply-sql.js sql/2026-05-24-billing-system.sql",
    "setup:billing": "node scripts/apply-sql.js sql/2026-05-24-billing-system.sql && node scripts/generate-sample-bills.js",
    "create:admin": "node create-admin.js",
    "check:users": "node check-users.js",
    "test:payment": "node test-recyclables-payment.js",
    "test:wallet": "node test-wallet-flow.js",
    "check:admins": "node check-admins.js",
    "seed:fleet": "node scripts/seed-fleet-data.js",
    "seed:fleet-api": "node scripts/seed-fleet-via-api.js",
    "cleanup:db": "node cleanup-postgres.js",
    "cleanup:postgres": "node cleanup-postgres.js",
    "cleanup:auth": "node cleanup-supabase-auth.js",
    "cleanup:orphaned": "node cleanup-orphaned-auth.js",
    "cleanup:all": "node cleanup-postgres.js && node cleanup-supabase-auth.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/jest/bin/jest.js --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs-modules/mailer": "^2.3.4",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.1.1",
    "@nestjs/passport": "^10.0.2",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/platform-socket.io": "^10.0.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^7.1.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^10.0.0",
    "@nestjs/websockets": "^10.0.0",
    "@sentry/node": "^10.52.0",
    "@sentry/profiling-node": "^10.52.0",
    "@supabase/supabase-js": "^2.105.4",
    "@types/compression": "^1.8.1",
    "@types/multer": "^2.1.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "handlebars": "^4.7.9",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "nest-commander": "^3.20.1",
    "nodemailer": "^8.0.7",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.11.3",
    "redis": "^4.6.8",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.2",
    "ts-loader": "^9.4.3",
    "typeorm": "^0.3.17",
    "typescript": "^5.1.3"
  },
  "devDependencies": {
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcrypt": "^5.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/passport-jwt": "^3.0.9",
    "@types/passport-local": "^1.0.35",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.1.2"
  }
}
