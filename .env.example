# Database Configuration
# Use either DATABASE_URL or the individual DB_* values below.
# The backend is Supabase Postgres-only; SQLite is not used.
DB_PROVIDER=postgres
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DB_SSL=true
DB_SYNC=false
DB_HOST=
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=postgres

# Supabase Auth
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_PASSWORD_REDIRECT_URL=http://localhost:3000/reset-password

# First admin bootstrap
# Set this once, run `npm run bootstrap:admin`, then rotate or remove it after the first admin exists.
BOOTSTRAP_ADMIN_TOKEN=replace-with-a-long-random-one-time-token

# Frontend Supabase Auth
VITE_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Legacy JWT values are no longer used for app authentication.
JWT_SECRET=legacy-local-dev-secret
JWT_EXPIRES_IN=7d

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Payment Integration
PAYSTACK_SECRET_KEY=your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=your-paystack-public-key

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Environment
NODE_ENV=development
PORT=3001

# Frontend maps
VITE_GEOAPIFY_API_KEY=your-geoapify-api-key
